# WasteBot Environment Configuration
# Copy this file to .env and fill in your values

# GROQ API Configuration (Required)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Specify the GROQ model
# Default: mixtral-8x7b-32768
# GROQ_MODEL=mixtral-8x7b-32768

# Server Configuration
WASTEBOT_PORT=8001
WASTEBOT_HOST=127.0.0.1

# Data directory for RAG pipeline
WASTEBOT_DATA_DIR=data

# Warmup: Initialize RAG pipeline on server startup (recommended)
WASTEBOT_WARMUP=1

# Rebuild vector store on startup
WASTEBOT_REBUILD=0

# CORS Configuration (comma-separated origins)
WASTEBOT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Suppress CLI prompts in server mode
WASTEBOT_NO_PROMPT=1
